# =============================================================================
# .env.example — fs-worker local configuration
#
# Copy this file to .env and fill in the values for your environment.
# .env is never committed to git.
#
# To use local (Multipass) mode: leave REMOTE_HOST empty or absent.
# To use remote (SSH bare-metal) mode: set REMOTE_HOST, REMOTE_USER, REMOTE_PEM.
#
# Remote mode is auto-activated when REMOTE_HOST is set — no need to pass
# --remote to the scripts explicitly.
#
# Typical workflow:
#   1. Fill in the AWS section below and run ./scripts/vm-provision.sh
#      It will create the EC2 instance and write REMOTE_HOST, REMOTE_PEM,
#      and REMOTE_POOL_DEVICE into this file automatically.
#   2. Run ./scripts/vm-setup.sh to provision the instance (ZFS, Rust, etc.)
#   3. Run ./scripts/vm-build.sh and ./scripts/vm-run.sh to start the worker.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS provisioning  (used by vm-provision.sh only)
# These are only needed when creating/destroying the EC2 instance.
# After running vm-provision.sh these are written automatically.
# -----------------------------------------------------------------------------

# AWS CLI named profile to use for all aws commands (optional).
# If unset, the AWS CLI default profile / ambient credentials are used.
# Run `aws configure list-profiles` to see available profiles.
# AWS_PROFILE=shahab-sandbox/AWSAdministratorAccess

# AWS region to provision the instance in (default: us-east-1)
# a1.metal availability varies by region — check before choosing.
# AWS_REGION=us-east-1

# EC2 instance type (default: a1.metal — ARM64 bare-metal Graviton)
# AWS_INSTANCE_TYPE=a1.metal

# Name of the EC2 key pair that already exists in your AWS account
# AWS_KEY_NAME=zfs-firecracker-key

# Local path to the PEM file for the key pair above
# AWS_PEM_PATH=~/.ssh/zfs-firecracker-key.pem

# Size in GB of the EBS data volume created for the ZFS pool (default: 20)
# AWS_EBS_SIZE_GB=20

# EBS volume type for the ZFS data volume (default: gp3)
# AWS_EBS_TYPE=gp3

# Optionally pin to an existing VPC / subnet / security group.
# Leave unset and vm-provision.sh will create dedicated ones tagged "fs-worker".
# AWS_VPC_ID=vpc-xxxxxxxxxxxxxxxxx
# AWS_SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
# AWS_SG_ID=sg-xxxxxxxxxxxxxxxxx

# Written automatically by vm-provision.sh — do not edit by hand.
# AWS_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Remote (SSH bare-metal) mode
# These are written automatically by vm-provision.sh.
# You can also fill them in manually to target any SSH-accessible machine.
# Leave unset to use local Multipass mode instead.
# -----------------------------------------------------------------------------

# IP address or hostname of the bare-metal Linux machine
# REMOTE_HOST=1.2.3.4

# SSH login user on the remote machine (default: ubuntu)
# REMOTE_USER=ubuntu

# Path to the PEM private key file on your Mac
# REMOTE_PEM=/path/to/key.pem

# SSH port on the remote machine (default: 22)
# REMOTE_PORT=22

# Absolute path to the project directory on the remote machine
# (default: /home/<REMOTE_USER>/fs-worker)
# REMOTE_WORK_DIR=/home/ubuntu/fs-worker

# Block device on the remote machine to use for the ZFS pool.
# This should be the raw EBS volume device path (e.g. /dev/nvme1n1 or /dev/xvdf).
# The device must be unformatted / not mounted — ZFS will take ownership of it.
# Run `lsblk` on the remote machine to find the right device name.
# Required in remote mode.
# REMOTE_POOL_DEVICE=/dev/nvme1n1

# -----------------------------------------------------------------------------
# Local (Multipass) mode
# -----------------------------------------------------------------------------

# Name of the Multipass VM (default: zfs-dev)
# VM_NAME=zfs-dev

# Mount path for the project inside the VM (default: /home/ubuntu/fs-worker)
# VM_MOUNT_PATH=/home/ubuntu/fs-worker

# -----------------------------------------------------------------------------
# ZFS
# -----------------------------------------------------------------------------

# ZFS pool name used by the worker (default: testpool)
# ZFS_POOL=testpool

# -----------------------------------------------------------------------------
# Temporal
# -----------------------------------------------------------------------------

# Address of the Temporal server the worker should connect to
# (default: http://localhost:7233)
# TEMPORAL_HOST=http://localhost:7233

# Temporal namespace (default: default)
# TEMPORAL_NAMESPACE=default

# Task queue the worker polls (default: fs-worker)
# TEMPORAL_TASK_QUEUE=fs-worker

# Deployment name used for worker versioning (default: fs-worker)
# TEMPORAL_DEPLOYMENT_NAME=fs-worker

# -----------------------------------------------------------------------------
# Worker process
# -----------------------------------------------------------------------------

# Log level filter passed to tracing-subscriber (default: info)
# RUST_LOG=info
