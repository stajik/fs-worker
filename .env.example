# =============================================================================
# .env.example — fs-worker local configuration
#
# Copy this file to .env and fill in the values for your environment.
# .env is never committed to git.
#
# To use local (Multipass) mode: leave REMOTE_HOST empty or absent.
# To use remote (SSH bare-metal) mode: set REMOTE_HOST, REMOTE_USER, REMOTE_PEM.
#
# Remote mode is auto-activated when REMOTE_HOST is set — no need to pass
# --remote to the scripts explicitly.
# =============================================================================

# -----------------------------------------------------------------------------
# Remote (SSH bare-metal) mode
# Leave these unset to use local Multipass mode instead.
# -----------------------------------------------------------------------------

# IP address or hostname of the bare-metal Linux machine
# REMOTE_HOST=1.2.3.4

# SSH login user on the remote machine (default: ubuntu)
# REMOTE_USER=ubuntu

# Path to the PEM private key file on your Mac
# REMOTE_PEM=/path/to/key.pem

# SSH port on the remote machine (default: 22)
# REMOTE_PORT=22

# Absolute path to the project directory on the remote machine
# (default: /home/<REMOTE_USER>/fs-worker)
# REMOTE_WORK_DIR=/home/ubuntu/fs-worker

# -----------------------------------------------------------------------------
# Local (Multipass) mode
# -----------------------------------------------------------------------------

# Name of the Multipass VM (default: zfs-dev)
# VM_NAME=zfs-dev

# Mount path for the project inside the VM (default: /home/ubuntu/fs-worker)
# VM_MOUNT_PATH=/home/ubuntu/fs-worker

# -----------------------------------------------------------------------------
# ZFS
# -----------------------------------------------------------------------------

# ZFS pool name used by the worker (default: testpool)
# ZFS_POOL=testpool

# -----------------------------------------------------------------------------
# Temporal
# -----------------------------------------------------------------------------

# Address of the Temporal server the worker should connect to
# (default: http://localhost:7233)
# TEMPORAL_HOST=http://localhost:7233

# Temporal namespace (default: default)
# TEMPORAL_NAMESPACE=default

# Task queue the worker polls (default: fs-worker)
# TEMPORAL_TASK_QUEUE=fs-worker

# Deployment name used for worker versioning (default: fs-worker)
# TEMPORAL_DEPLOYMENT_NAME=fs-worker

# -----------------------------------------------------------------------------
# Worker process
# -----------------------------------------------------------------------------

# Log level filter passed to tracing-subscriber (default: info)
# RUST_LOG=info
